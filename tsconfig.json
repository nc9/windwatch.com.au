{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"esModuleInterop": true,
		"strict": true,
		"jsx": "react-jsx",
		"skipLibCheck": true,
		"outDir": "dist",
		"rootDir": "."
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.tsx",
		"scripts/**/*.ts",
		"vite.config.ts"
	]
}

{
	"name": "windwatch.com.au",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "VITE_MODE=wind vite",
		"dev:solar": "VITE_MODE=solar vite",
		"build": "vite build",
		"preview": "vite preview",
		"lint": "ultracite check",
		"format": "ultracite fix",
		"generate:facilities": "bun run scripts/generate-facilities.ts",
		"generate:facilities:solar": "FUELTECH=solar_utility bun run scripts/generate-facilities.ts",
		"generate:wind": "bun run scripts/generate-wind.ts",
		"generate:solar": "bun run scripts/generate-solar.ts",
		"generate": "bun run --sequential generate:facilities generate:wind",
		"generate:all": "bun run --sequential generate:facilities generate:facilities:solar generate:wind generate:solar"
	},
	"dependencies": {
		"@tanstack/react-query": "^5.90.21",
		"@vercel/blob": "^0.27.1",
		"@vercel/kv": "^3.0.0",
		"maplibre-gl": "4",
		"openelectricity": "latest",
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.1.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vercel/node": "^5.6.16",
		"@vitejs/plugin-react": "^4.4.0",
		"oxfmt": "^0.41.0",
		"oxlint": "^1.56.0",
		"tailwindcss": "^4.1.0",
		"typescript": "^5.8.0",
		"ultracite": "7.3.2",
		"vite": "^6.3.0",
		"yallist": "3.1.1"
	}
}
